{
  "name": "backend",
  "version": "1.0.0",
  "private": true,
  "description": "Stock Intelligence Platform - Backend API",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest --coverage",
    "db:migrate": "psql $DATABASE_URL -f src/db/schema.sql",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.20.0",
    "@fastify/cors": "^8.5.0",
    "fastify": "^4.26.0",
    "node-cron": "^3.0.3",
    "pg": "^8.11.3",
    "rss-parser": "^3.13.0",
    "xml2js": "^0.6.2",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^20.11.5",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.11.0",
    "@types/xml2js": "^0.4.14",
    "@vitest/coverage-v8": "^1.2.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^1.2.0"
  }
}
